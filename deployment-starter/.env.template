# CerbaSeal — Docker Environment Template
# Copy to .env and edit the values marked REQUIRED before running docker compose up.
#
# Usage:
#   cp .env.template .env
#   # Edit .env — set CERBASEAL_ENV at minimum
#   docker compose up

# REQUIRED: deployment environment
# Values: production | staging | dev
CERBASEAL_ENV=production

# Port the gate HTTP server listens on (default: 3000)
PORT=3000

# Audit log file path inside the container.
# Maps to ./data/audit.jsonl on the host (via the ./data volume mount).
# Must be within /app/data/ to survive container restarts.
LOG_PATH=/app/data/audit.jsonl

# Optional: explicit path to cerbaseal.policy.json inside the container.
# Default: /app/cerbaseal.policy.json (baked into the image from deployment-starter/).
# To use a custom policy file without rebuilding:
#   1. Place your policy file at ./cerbaseal.policy.json (host)
#   2. Add to docker-compose.yml volumes: - ./cerbaseal.policy.json:/app/cerbaseal.policy.json
#   3. Set POLICY_PATH here
# POLICY_PATH=/app/cerbaseal.policy.json
