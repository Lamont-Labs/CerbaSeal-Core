{
  "name": "cerbaseal-review",
  "version": "0.1.0",
  "private": true,
  "description": "CerbaSeal review repo - Drop 01 execution enforcement spine",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx examples/run-demo.ts",
    "demo:web": "tsx examples/browser-demo/server.ts",
    "demo:web:validate": "tsx examples/browser-demo/validate-demo.ts",
    "demo:consumer": "tsx examples/consumer-example/consumer.ts",
    "demo:consumer:validate": "tsx examples/consumer-example/validate-consumer.ts",
    "demo:agent": "tsx examples/agent-gate/run-agent-gate.ts",
    "demo:agent:validate": "tsx examples/agent-gate/validate-agent-gate.ts",
    "demo:audit": "tsx examples/auditor-view/run-auditor-view.ts",
    "demo:audit:validate": "tsx examples/auditor-view/validate-auditor-view.ts",
    "demo:support": "tsx examples/support-readiness/run-support-readiness.ts",
    "demo:support:validate": "tsx examples/support-readiness/validate-support-readiness.ts",
    "demo:all": "pnpm demo && pnpm demo:consumer && pnpm demo:agent && pnpm demo:audit && pnpm demo:support",
    "report:hash": "ts-node scripts/hash-report.ts",
    "report:list": "cat docs/reports/adversarial/index.json"
  },
  "dependencies": {
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
